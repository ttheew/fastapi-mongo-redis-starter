# App
APP_NAME=app
ENV=dev

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=app
MONGO_TLS=false
MONGO_TLS_CA_FILE=
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_IDLE_TIME_MS=60000
MONGO_RETRY_WRITES=true
MONGO_RETRY_READS=true
MONGO_WRITE_CONCERN_W=majority
MONGO_JOURNAL=true
MONGO_WTIMEOUT_MS=10000

# Redis
REDIS_URI=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_TLS_CA_FILE=
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=10
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_RETRY_ATTEMPTS=3
REDIS_RETRY_BACKOFF_BASE=0.25
REDIS_RETRY_BACKOFF_CAP=8

# HTTP Client
HTTP_BASE_URL=
HTTP_SSL=true
HTTP_CONNECTOR_LIMIT=100
HTTP_TIMEOUT_TOTAL=30
HTTP_TIMEOUT_CONNECT=5
HTTP_TIMEOUT_SOCK_READ=25
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_BACKOFF_BASE=0.5
HTTP_RETRY_BACKOFF_MAX=16

# Demo helpers
HTTP_DEMO_BASE_URL=https://httpbin.org
HTTP_DEMO_SSE_URL=
